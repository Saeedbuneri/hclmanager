rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin check — desktop app signs in as hcl@lab.local
    function isAdmin() {
      return request.auth != null && 
             request.auth.token.email in ['hcl@lab.local'];
    }

    // Tests Catalog: only admins
    match /tests_catalog/{testId} {
      allow read, write: if isAdmin();
    }

    // Reports: admins check all; patients see ONLY their own record
    match /reports/{patientId} {
      allow write: if isAdmin();
      allow read: if isAdmin() ||
        (request.auth != null && 
         request.auth.token.email == patientId.lower() + '@lab.local');
    }

    // ✅ Notes/Tasks/Expenses: only admins (desktop app only)
    match /notes/{noteId} {
      allow read, write: if isAdmin();
    }

    // ✅ Patient Dues Ledger: only admins
    match /patient_dues/{dueId} {
      allow read, write: if isAdmin();
    }

    // Block everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
